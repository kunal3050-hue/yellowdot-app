rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// Yellow Dot — Firestore Security Rules
// Multi-school SaaS isolation: every document is scoped to a schoolId.
// A user may only access documents whose schoolId matches their own.
//
// Enforcement model
// ─────────────────
// The Node.js backend runs as Firebase Admin (bypasses these rules).
// These rules are a second layer of defence against:
//   • Direct SDK access from a compromised or misbehaving client
//   • Accidental client-side queries that skip the backend
//
// Roles (stored in users/{uid}.role)
//   developer   — unrestricted within own school
//   super_admin — unrestricted within own school
//   admin       — unrestricted within own school
//   center_admin— CRUD within own school (centerId enforced server-side)
//   teacher     — read all; write attendance, nap, food-consumption
//   accountant  — read all; write invoices, payments, fee-templates
//   reception   — read students; write attendance, parent-attendance
//   parent      — read their own student's records only
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Core helpers ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Read caller's Firestore user document (cached per request by Firestore).
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function mySchoolId() {
      return me().schoolId;
    }

    function myRole() {
      return me().role;
    }

    function isActive() {
      return me().status == 'active';
    }

    // True when the document's schoolId matches the caller's schoolId.
    function sameSchool(docSchoolId) {
      return mySchoolId() == docSchoolId;
    }

    // True when a new document being written carries the caller's schoolId.
    function writingSameSchool() {
      return request.resource.data.schoolId == mySchoolId();
    }

    // ── Role predicates ─────────────────────────────────────────────────

    function isSuperAdmin() {
      return myRole() in ['developer', 'super_admin'];
    }

    function isAdmin() {
      return myRole() in ['developer', 'super_admin', 'admin'];
    }

    function isCenterAdmin() {
      return myRole() in ['developer', 'super_admin', 'admin', 'center_admin'];
    }

    function isTeacherOrAbove() {
      return myRole() in ['developer', 'super_admin', 'admin', 'center_admin', 'teacher'];
    }

    function isFinance() {
      return myRole() in ['developer', 'super_admin', 'admin', 'accountant'];
    }

    function isReceptionOrAbove() {
      return myRole() in ['developer', 'super_admin', 'admin', 'center_admin', 'teacher', 'reception'];
    }

    function isStaff() {
      return myRole() in ['developer', 'super_admin', 'admin', 'center_admin',
                          'teacher', 'accountant', 'reception'];
    }

    function isParent() {
      return myRole() == 'parent';
    }

    // Parents: student they are linked to (stored in users/{uid}.studentId)
    function myStudentId() {
      return me().studentId;
    }

    // ── Parent Module identity (parents/{uid}) ──────────────────────────
    // First-class parent account doc, keyed by Firebase uid. Parents have no
    // users/{uid} doc, so parent-scoped access is resolved from here instead.
    // These helpers use exists() first so staff (no parents doc) short-circuit
    // safely without triggering a missing-doc error.
    function isParentAccount() {
      return exists(/databases/$(database)/documents/parents/$(request.auth.uid));
    }

    function myParent() {
      return get(/databases/$(database)/documents/parents/$(request.auth.uid)).data;
    }

    function myLinkedStudentIds() {
      return isParentAccount() ? myParent().studentIds : [];
    }

    // ════════════════════════════════════════════════════════════════════
    // TENANTS — platform-level school registry
    // Only super_admin / developer may read or write.
    // All writes go through the backend (Admin SDK) but these rules
    // prevent direct client-side access.
    // ════════════════════════════════════════════════════════════════════

    match /tenants/{tenantId} {
      allow read:  if isSignedIn() && isSuperAdmin();
      allow write: if isSignedIn() && isSuperAdmin();
    }

    match /tenantAuditLogs/{logId} {
      allow read:  if isSignedIn() && isSuperAdmin();
      allow write: if false; // backend-only writes
    }

    // ════════════════════════════════════════════════════════════════════
    // USERS
    // ════════════════════════════════════════════════════════════════════

    match /users/{userId} {
      // Any signed-in user may read their own doc (needed for role resolution).
      // Admins may read any user in their school.
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        (isAdmin() && sameSchool(resource.data.schoolId))
      );

      // Only admins may create users, and only within their own school.
      allow create: if isSignedIn() && isAdmin() && isActive() &&
        writingSameSchool();

      // Admins may update any user in their school.
      // A user may update their own non-critical fields (name, photoUrl).
      allow update: if isSignedIn() && (
        (isAdmin() && isActive() && sameSchool(resource.data.schoolId)) ||
        (request.auth.uid == userId &&
          // Prevent self-promotion: role and schoolId must not change
          request.resource.data.role     == resource.data.role &&
          request.resource.data.schoolId == resource.data.schoolId &&
          request.resource.data.status   == resource.data.status)
      );

      // No hard deletes from the client. Use status: 'inactive'.
      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // PARENTS  (Parent Module V1 — parents/{uid} identity docs)
    // Written exclusively by the backend (Admin SDK) on first parent access.
    // Client rules below are a defensive second layer.
    // ════════════════════════════════════════════════════════════════════

    match /parents/{parentUid} {
      // A parent reads only their own doc; admins read any parent in their school.
      allow read: if isSignedIn() && (
        request.auth.uid == parentUid ||
        (isAdmin() && sameSchool(resource.data.schoolId))
      );

      // Only admins may write parent docs from the client.
      // (Provisioning happens server-side via the Admin SDK.)
      allow create, update: if isSignedIn() && isAdmin() && isActive() &&
        writingSameSchool();

      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // STUDENTS
    // ════════════════════════════════════════════════════════════════════

    match /students/{studentId} {
      // Staff: read any student in their school.
      // Parent (parents/{uid} account): read only their own linked children.
      // Parent-account clause is first so staff short-circuit via exists().
      allow read: if isSignedIn() && (
        (isParentAccount() &&
          resource.data.schoolId == myParent().schoolId &&
          resource.data.studentId in myLinkedStudentIds()) ||
        (isStaff()  && sameSchool(resource.data.schoolId)) ||
        (isParent() && sameSchool(resource.data.schoolId) &&
          resource.data.studentId == myStudentId())
      );

      allow create: if isSignedIn() && isCenterAdmin() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId) &&
        // schoolId must not change on update
        request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);

      // ── Medical record subcollection ──────────────────────────────────
      // Inherits school isolation from the parent student document.
      match /medical/{record} {
        function parentStudent() {
          return get(/databases/$(database)/documents/students/$(studentId)).data;
        }

        allow read: if isSignedIn() && (
          (isStaff()  && sameSchool(parentStudent().schoolId)) ||
          (isParent() && sameSchool(parentStudent().schoolId) &&
            studentId == myStudentId())
        );

        allow write: if isSignedIn() && isTeacherOrAbove() && isActive() &&
          sameSchool(parentStudent().schoolId);
      }

      // ── Notes subcollection ───────────────────────────────────────────
      match /notes/{noteId} {
        function parentStudentForNote() {
          return get(/databases/$(database)/documents/students/$(studentId)).data;
        }

        allow read: if isSignedIn() && isStaff() &&
          sameSchool(parentStudentForNote().schoolId);

        allow create, update: if isSignedIn() && isTeacherOrAbove() && isActive() &&
          sameSchool(parentStudentForNote().schoolId);

        allow delete: if isSignedIn() && isCenterAdmin() && isActive() &&
          sameSchool(parentStudentForNote().schoolId);
      }
    }

    // ════════════════════════════════════════════════════════════════════
    // ATTENDANCE
    // ════════════════════════════════════════════════════════════════════

    match /attendance/{entryId} {
      // Parents can read their own children's attendance.
      // Parent-account clause first so staff short-circuit via exists().
      allow read: if isSignedIn() && (
        (isParentAccount() &&
          resource.data.schoolId == myParent().schoolId &&
          resource.data.studentId in myLinkedStudentIds()) ||
        (isStaff()  && sameSchool(resource.data.schoolId)) ||
        (isParent() && sameSchool(resource.data.schoolId) &&
          resource.data.studentId == myStudentId())
      );

      allow create: if isSignedIn() && isReceptionOrAbove() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isReceptionOrAbove() && isActive() &&
        sameSchool(resource.data.schoolId);

      // Only admins can delete attendance records.
      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // NAP LOGS
    // ════════════════════════════════════════════════════════════════════

    match /napLogs/{napId} {
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      allow create: if isSignedIn() && isTeacherOrAbove() && isActive() &&
        writingSameSchool();

      // wakeUp updates duration/status/endTime — teacher or above.
      allow update: if isSignedIn() && isTeacherOrAbove() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // FOOD MENU
    // ════════════════════════════════════════════════════════════════════

    match /foodMenus/{menuId} {
      // All staff may read the menu.
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      // Center admins and above manage the menu.
      allow create: if isSignedIn() && isCenterAdmin() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // FOOD CONSUMPTION
    // ════════════════════════════════════════════════════════════════════

    match /foodConsumption/{entryId} {
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      // Teachers record consumption.
      allow create, update: if isSignedIn() && isTeacherOrAbove() && isActive() &&
        writingSameSchool();

      allow delete: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // CAMERAS (CCTV V2 — metadata only; no streaming)
    // CCTV_VIEW: any staff may read.  CCTV_MANAGE: admin-tier writes.
    // ════════════════════════════════════════════════════════════════════

    match /cameras/{cameraId} {
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      allow create: if isSignedIn() && isCenterAdmin() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // PICKUP LOGS  (type: "authorization" | "history")
    // ════════════════════════════════════════════════════════════════════

    match /pickupLogs/{entryId} {
      // Staff can read both types.
      // Parents can read their own student's pickup records.
      allow read: if isSignedIn() && (
        (isStaff()  && sameSchool(resource.data.schoolId)) ||
        (isParent() && sameSchool(resource.data.schoolId) &&
          resource.data.studentId == myStudentId())
      );

      // Reception and above can create authorization records.
      // Only backend (Admin SDK) records history in practice, but
      // allow center_admin+ as a safety net.
      allow create: if isSignedIn() && isCenterAdmin() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // PARENT ATTENDANCE
    // ════════════════════════════════════════════════════════════════════

    match /parentAttendance/{entryId} {
      // Staff can read all; parents can read their own student's records.
      allow read: if isSignedIn() && (
        (isStaff()  && sameSchool(resource.data.schoolId)) ||
        (isParent() && sameSchool(resource.data.schoolId) &&
          resource.data.studentId == myStudentId())
      );

      // Parents create their own check-in/out records via the backend.
      // Reception and above can also write.
      allow create: if isSignedIn() && isActive() && (
        (isReceptionOrAbove() && writingSameSchool()) ||
        (isParent() && writingSameSchool() &&
          request.resource.data.studentId == myStudentId())
      );

      // Updates only by reception and above (e.g., corrections).
      allow update: if isSignedIn() && isReceptionOrAbove() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // INVOICES
    // ════════════════════════════════════════════════════════════════════

    match /invoices/{invoiceId} {
      // Finance roles and parents (own children).
      // Parent-account clause first so staff short-circuit via exists().
      allow read: if isSignedIn() && (
        (isParentAccount() &&
          resource.data.schoolId == myParent().schoolId &&
          resource.data.studentId in myLinkedStudentIds()) ||
        (isFinance()         && sameSchool(resource.data.schoolId)) ||
        (isTeacherOrAbove()  && sameSchool(resource.data.schoolId)) ||
        (isParent()          && sameSchool(resource.data.schoolId) &&
          resource.data.studentId == myStudentId())
      );

      allow create: if isSignedIn() && isFinance() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isFinance() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // PAYMENTS
    // ════════════════════════════════════════════════════════════════════

    match /payments/{paymentId} {
      // Parent-account clause first so staff short-circuit via exists().
      allow read: if isSignedIn() && (
        (isParentAccount() &&
          resource.data.schoolId == myParent().schoolId &&
          resource.data.studentId in myLinkedStudentIds()) ||
        (isFinance()        && sameSchool(resource.data.schoolId)) ||
        (isTeacherOrAbove() && sameSchool(resource.data.schoolId)) ||
        (isParent()         && sameSchool(resource.data.schoolId) &&
          resource.data.studentId == myStudentId())
      );

      allow create: if isSignedIn() && isFinance() && isActive() &&
        writingSameSchool();

      // Payments are generally immutable — only admins may correct.
      allow update: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // FEE TEMPLATES
    // ════════════════════════════════════════════════════════════════════

    match /feeTemplates/{templateId} {
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      allow create: if isSignedIn() && isFinance() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isFinance() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // SETTINGS
    // ────────────────────────────────────────────────────────────────────
    // NOTE: The settings collection currently uses per-section documents
    // (e.g. settings/branding, settings/notifications) without a schoolId
    // field, because the backend is the sole writer (Admin SDK).
    // These rules lock down client-side access defensively.
    // Future: restructure as settings/{schoolId}/sections/{section}.
    // ════════════════════════════════════════════════════════════════════

    match /settings/{section} {
      // Any authenticated staff member can read settings.
      allow read: if isSignedIn() && isStaff();

      // Only admins may write settings from the client.
      // In practice, all settings writes go through the backend (Admin SDK).
      allow write: if isSignedIn() && isAdmin() && isActive();
    }

    // ════════════════════════════════════════════════════════════════════
    // MEMORIES  (Parent Module V1 — photos/videos per child)
    // Staff write; parents read only their linked children's memories.
    // ════════════════════════════════════════════════════════════════════

    match /memories/{memoryId} {
      // Parent-account clause first so staff short-circuit via exists().
      allow read: if isSignedIn() && (
        (isParentAccount() &&
          resource.data.schoolId == myParent().schoolId &&
          resource.data.studentId in myLinkedStudentIds()) ||
        (isStaff() && sameSchool(resource.data.schoolId))
      );

      allow create, update: if isSignedIn() && isTeacherOrAbove() && isActive() &&
        writingSameSchool();

      allow delete: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS  (Parent Module V2)
    // Written exclusively by the backend (Admin SDK).
    // Parents may read/update (mark as read) only their own notifications.
    // ════════════════════════════════════════════════════════════════════

    match /notifications/{notifId} {
      // A parent may read only their own notifications.
      allow read: if isSignedIn() && (
        isParentAccount() && resource.data.parentId == request.auth.uid
      );

      // A parent may mark a notification as read (update read field only).
      allow update: if isSignedIn() &&
        isParentAccount() &&
        resource.data.parentId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);

      // Only the backend (Admin SDK) creates or deletes notifications.
      allow create, delete: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // FAMILIES  (Sibling & Family Management)
    // Staff read/write; parents have no direct client access (backend only).
    // ════════════════════════════════════════════════════════════════════

    match /families/{familyId} {
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      allow create: if isSignedIn() && isCenterAdmin() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId);

      // ── Notes subcollection ──────────────────────────────────────
      match /notes/{noteId} {
        allow read:   if isSignedIn() && isStaff();
        allow create: if isSignedIn() && isTeacherOrAbove() && isActive();
        allow delete: if isSignedIn() && isCenterAdmin() && isActive();
        allow update: if false;
      }

      // ── Documents subcollection ──────────────────────────────────
      match /documents/{docId} {
        allow read:          if isSignedIn() && isStaff();
        allow create, delete:if isSignedIn() && isCenterAdmin() && isActive();
        allow update:        if false;
      }

      // ── Timeline subcollection (backend-only writes) ─────────────
      match /timeline/{eventId} {
        allow read:  if isSignedIn() && isStaff();
        allow write: if false;
      }
    }

    // ════════════════════════════════════════════════════════════════════
    // RELEASE MODULES  (Staged Release Dashboard — module status registry)
    // Written exclusively by the backend (Admin SDK).
    // Only developer / super_admin may read from the client.
    // ════════════════════════════════════════════════════════════════════

    match /releaseModules/{docId} {
      allow read: if isSignedIn() && isAdmin() &&
        sameSchool(resource.data.schoolId);

      // All mutations go through the backend (Admin SDK); block direct client writes.
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // RELEASE AUDITS  (Immutable event log for every promote / rollback)
    // Written exclusively by the backend (Admin SDK).
    // Developer / super_admin may read; no client writes ever.
    // ════════════════════════════════════════════════════════════════════

    match /releaseAudits/{auditId} {
      allow read: if isSignedIn() && isAdmin() &&
        sameSchool(resource.data.schoolId);

      // Audit log is immutable from the client — backend-only writes.
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // STAFF  (HR records — Phase 1 Staff Management)
    // Tenant-isolated by schoolId. Staff may read their own record only;
    // managers may read/write everything inside their school.
    // ════════════════════════════════════════════════════════════════════

    match /staff/{staffId} {
      // Self-read is allowed even for non-managers (so teachers can see
      // their own profile in the future "My Profile" screen).
      allow read: if isSignedIn() && (
        (isStaff()      && sameSchool(resource.data.schoolId)) ||
        (resource.data.linkedUserId == request.auth.uid)
      );

      allow create: if isSignedIn() && isCenterAdmin() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId) &&
        // schoolId, tenantId, employeeCode and staffId are immutable
        request.resource.data.schoolId     == resource.data.schoolId &&
        request.resource.data.tenantId     == resource.data.tenantId &&
        request.resource.data.employeeCode == resource.data.employeeCode &&
        request.resource.data.staffId      == resource.data.staffId;

      // Hard deletes are blocked from clients. Use the soft-delete endpoint
      // (PUT/DELETE through the backend) which flips status to "inactive".
      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // DEPARTMENTS  (Staff Management — master list)
    // ════════════════════════════════════════════════════════════════════

    match /departments/{deptId} {
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      allow create: if isSignedIn() && isCenterAdmin() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId;

      // System departments cannot be deleted from the client. The backend
      // controller enforces this rule for non-system docs too.
      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId) &&
        resource.data.isSystem != true;
    }

    // ════════════════════════════════════════════════════════════════════
    // DESIGNATIONS  (Staff Management — master list)
    // ════════════════════════════════════════════════════════════════════

    match /designations/{designationId} {
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      allow create: if isSignedIn() && isCenterAdmin() && isActive() &&
        writingSameSchool();

      allow update: if isSignedIn() && isCenterAdmin() && isActive() &&
        sameSchool(resource.data.schoolId) &&
        request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if isSignedIn() && isAdmin() && isActive() &&
        sameSchool(resource.data.schoolId) &&
        resource.data.isSystem != true;
    }

    // ════════════════════════════════════════════════════════════════════
    // EMPLOYEE TIMELINE  (Staff Management — append-only event log)
    // Only the backend (Admin SDK) writes these. Staff may read events
    // within their school; everyone else is denied.
    // ════════════════════════════════════════════════════════════════════

    match /employeeTimeline/{eventId} {
      allow read: if isSignedIn() && isStaff() &&
        sameSchool(resource.data.schoolId);

      // All writes are server-side via the Admin SDK.
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // PHASE 2 — STAFF ATTENDANCE
    // ════════════════════════════════════════════════════════════════════

    match /staffShifts/{shiftId} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isCenterAdmin() && isActive() && writingSameSchool();
    }

    match /staffAttendance/{id} {
      allow read: if isSignedIn() && (
        (isStaff() && sameSchool(resource.data.schoolId)) ||
        // Staff can read their own attendance via the linked staff doc — backend enforces in practice
        (resource.data.staffId == request.auth.uid)
      );
      allow create: if isSignedIn() && isReceptionOrAbove() && isActive() && writingSameSchool();
      allow update: if isSignedIn() && isReceptionOrAbove() && isActive() && sameSchool(resource.data.schoolId);
      allow delete: if false; // soft-delete via backend
    }

    // ════════════════════════════════════════════════════════════════════
    // PHASE 3 — LEAVE MANAGEMENT
    // ════════════════════════════════════════════════════════════════════

    match /leaveTypes/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isCenterAdmin() && isActive() && writingSameSchool();
    }

    match /leaveBalances/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if false; // backend-only (Admin SDK)
    }

    match /leaveRequests/{id} {
      allow read: if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow create: if isSignedIn() && isStaff() && isActive() && writingSameSchool();
      allow update: if isSignedIn() && isCenterAdmin() && isActive() && sameSchool(resource.data.schoolId);
      allow delete: if false; // soft-delete via backend
    }

    // ════════════════════════════════════════════════════════════════════
    // PHASE 4 — PAYROLL
    // ════════════════════════════════════════════════════════════════════

    match /salaryComponents/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isFinance() && isActive() && writingSameSchool();
    }

    match /salaryStructures/{id} {
      allow read:  if isSignedIn() && isFinance() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isFinance() && isActive() && writingSameSchool();
    }

    match /staffSalary/{staffId} {
      // Salary is sensitive — only finance + admins may read.
      allow read:  if isSignedIn() && isFinance() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isFinance() && isActive() && writingSameSchool();
    }

    match /payrollRuns/{id} {
      allow read:  if isSignedIn() && isFinance() && sameSchool(resource.data.schoolId);
      allow write: if false; // backend-only
    }

    match /payslips/{id} {
      allow read: if isSignedIn() && (
        (isFinance() && sameSchool(resource.data.schoolId)) ||
        // Employee may read their own payslip if linked
        (resource.data.staffId == request.auth.uid)
      );
      allow write: if false; // backend-only
    }

    // ════════════════════════════════════════════════════════════════════
    // PHASE 5 — PERFORMANCE MANAGEMENT
    // ════════════════════════════════════════════════════════════════════

    match /performanceKpis/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isCenterAdmin() && isActive() && writingSameSchool();
    }

    match /performanceReviews/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isCenterAdmin() && isActive() && writingSameSchool();
    }

    match /performanceGoals/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isCenterAdmin() && isActive() && writingSameSchool();
    }

    match /parentFeedback/{id} {
      allow read: if isSignedIn() && (
        (isStaff() && sameSchool(resource.data.schoolId)) ||
        (isParentAccount() && resource.data.parentId == request.auth.uid)
      );
      allow create: if isSignedIn() && isActive() && writingSameSchool();
      allow update, delete: if isSignedIn() && isCenterAdmin() && isActive() && sameSchool(resource.data.schoolId);
    }

    match /staffPromotions/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isAdmin() && isActive() && writingSameSchool();
    }

    match /staffAwards/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isCenterAdmin() && isActive() && writingSameSchool();
    }

    match /performanceTimeline/{id} {
      allow read:  if isSignedIn() && isStaff() && sameSchool(resource.data.schoolId);
      allow write: if false; // backend-only
    }

    // ════════════════════════════════════════════════════════════════════
    // DENY EVERYTHING ELSE
    // Any collection not explicitly listed above is fully locked down.
    // ════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
