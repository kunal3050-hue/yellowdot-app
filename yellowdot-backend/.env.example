# ─── Yellow Dot Backend — Environment Variables ────────────────────────────────
# Copy this file to .env (local dev) or set these in Railway/Render (production).

PORT=5000
SCHOOL_ID=ydseawoods

# CORS — comma-separated list of allowed frontend origins
# Local dev:   http://localhost:5173
# Production:  https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ── Firebase Admin Auth ──────────────────────────────────────────────────────
#
# OPTION A — Production (Railway / Render):
#   Paste the entire contents of serviceAccountKey.json as a single JSON string.
#   Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
#
#   FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"yellowdot-app",...}
#
# OPTION B — Local development:
#   Download the service account JSON and reference it by path.
#
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# ── CCTV credential encryption (AES-256-GCM) ─────────────────────────────────
# 32-byte key as 64 hex chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production so camera passwords are encrypted at rest.
CCTV_ENCRYPTION_KEY=
# Set to "true" in production to FAIL CLOSED: if the key is missing/invalid,
# camera saves are rejected instead of silently storing plaintext.
# Set the key first, run scripts/encryptCameraPasswords.js, THEN enable this.
CCTV_REQUIRE_ENCRYPTION=false
