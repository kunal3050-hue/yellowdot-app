# Railway/Nixpacks build config.
# firebase-functions@4.9 declares a peer of firebase-admin ^10||^11||^12, but the
# app pins firebase-admin@^13. The runtime path that matters in production is the
# standalone Express server (server.js on Railway); firebase-functions is only used
# by the unused Cloud Functions wrapper (index.js). The version mismatch is benign
# at runtime but makes a strict `npm ci` abort with ERESOLVE, which was failing the
# Railway build and leaving a stale backend deployed.
#
# legacy-peer-deps mirrors npm's own suggested remediation and matches the install
# that builds + boots cleanly. No dependency versions or app code are changed.
legacy-peer-deps=true
