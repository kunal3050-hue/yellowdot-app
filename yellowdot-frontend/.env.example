# ─── Yellow Dot Frontend — Environment Variables ───────────────────────────────
# Copy this file to .env (local dev) or set these in Vercel's dashboard (production).

# Backend API URL
# Local dev:   http://localhost:5000
# Production:  leave empty — Firebase Hosting rewrites /api/** to Cloud Functions
#              (see firebase.json → hosting.rewrites)
VITE_API_URL=http://localhost:5000

# Firebase — get these from Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
