# ─── Yellow Dot / KUE BOXS Care Frontend — Environment Variables ───────────────
# Copy this file to .env (local dev).
# For cloud builds use the mode-specific files:
#   .env.staging    → npm run build:staging   (Yellow Dot staging deploy)
#   .env.production → npm run build:production (KUE BOXS Care production deploy)

# Backend API URL
# Local dev:   http://localhost:5000
# Staging/Prod: https://backend-production-3608.up.railway.app
VITE_API_URL=http://localhost:5000

# ── App Environment ────────────────────────────────────────────────────────────
# Controls feature flags and the environment badge in Settings → Release & Build.
# Values: development | staging | production
VITE_APP_ENV=development

# Display name shown in the app header and PWA manifest.
# Yellow Dot = development/staging app; KUE BOXS Care = production app.
VITE_APP_NAME=Yellow Dot

# Semantic version — keep in sync with releaseNotes.js CURRENT_VERSION.
VITE_APP_VERSION=1.2.0

# Firebase — get these from Firebase Console → Project Settings → Your Apps
# IMPORTANT: VITE_FIREBASE_AUTH_DOMAIN controls where the Google Sign-In popup /
# redirect lands. Set this to the deployment's user-facing host so OAuth stays
# on-brand:
#   development: yellowdot-app.firebaseapp.com
#   staging    : yellowdot-app.firebaseapp.com
#   production : app.kueboxs.com  (must be in Firebase Auth → Authorized domains)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# FCM Web Push — VAPID key for browser push notifications
# Get it from: Firebase Console → Project Settings → Cloud Messaging
# → Web Push certificates → Generate key pair → copy the Key pair value
VITE_FCM_VAPID_KEY=
